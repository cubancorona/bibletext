 - (void)render:(CADisplayLink*)displayLink {
-    [self.glview display];
+    // BibleText on-demand present: only drive Fyne's GL draw when it actually has a new
+    // frame (Fyne sets the flag in Publish(), which the driver calls for dirty frames
+    // only). On an idle tick we skip [glview display], so the GLKView does NOT swap its
+    // double buffer to a stale frame — that stale swap is the scroll flicker seen while a
+    // Fyne VScroll/List updates — and the main thread stays free for native scroll
+    // compositing. Safe: this fires every tick, so a pending Publish() is serviced within
+    // one frame (drawloop then consumes the publish).
+    if (iosTakePresent()) {
+        [self.glview display];
+    }
 }
 
