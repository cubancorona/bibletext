+// iosTakePresent reports (and clears) whether Fyne has a real frame to present this
+// CADisplayLink tick — set by Publish() in app.go on dirty frames only. render: (in
+// darwin_ios.m) calls [glview display] ONLY when this returns 1, so idle ticks don't
+// swap the GLKView's double buffer to a stale frame (the scroll flicker) and leave the
+// main thread free for native UIScrollView compositing. Deadlock-safe: render: fires
+// every tick, so a Publish() that set the flag (then blocks on publishResult) is
+// serviced — drawloop runs, consumes theApp.publish — within one frame.
+//
+//export iosTakePresent
+func iosTakePresent() C.int {
+	if atomic.SwapInt32(&presentPending, 0) != 0 {
+		return 1
+	}
+	return 0
 }
 
